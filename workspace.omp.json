{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "console_title_template": "{{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "plain",
          "foreground": "cyan",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3,
            "folder_separator_icon": "/",
            "home_icon": "~"
          },
          "template": "{{ .Path }}"
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "yellow",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}magenta{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}red{{ end }}",
            "{{ if gt .Behind 0 }}red{{ end }}",
            "{{ if gt .Ahead 0 }}cyan{{ end }}"
          ],
          "properties": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": false
          },
          "template": "  {{ .HEAD }}{{ if or (.Working.Changed) (.Staging.Changed) }} *{{ end }}{{ if gt .Ahead 0 }} ↑{{ .Ahead }}{{ end }}{{ if gt .Behind 0 }} ↓{{ .Behind }}{{ end }}"
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "darkGray",
          "properties": {
            "threshold": 500,
            "style": "austin"
          },
          "template": "  {{ .FormattedMs }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "node",
          "style": "plain",
          "foreground": "green",
          "properties": {
            "fetch_version": true,
            "display_mode": "files"
          },
          "template": "node {{ .Full }}"
        },
        {
          "type": "python",
          "style": "plain",
          "foreground": "yellow",
          "properties": {
            "fetch_version": true,
            "display_mode": "files"
          },
          "template": "  py {{ .Full }}"
        },
        {
          "type": "go",
          "style": "plain",
          "foreground": "cyan",
          "properties": {
            "fetch_version": true,
            "display_mode": "files"
          },
          "template": "  go {{ .Full }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "green",
          "foreground_templates": [
            "{{ if gt .Code 0 }}red{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "template": "❯ "
        }
      ]
    }
  ],
  "transient_prompt": {
    "background": "transparent",
    "foreground": "darkGray",
    "template": "❯ "
  },
  "secondary_prompt": {
    "background": "transparent",
    "foreground": "darkGray",
    "template": "  "
  }
}
